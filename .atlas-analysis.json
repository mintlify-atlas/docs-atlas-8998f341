  "keyFeatures": [
    "Automated compilation for ASM, BASIC, C, and 8BP library",
    "DSK/CDT/CPR disk and tape image generation",
    "PNG to ASM sprite conversion with CPC palette support",
    "PNG to SCN loading screen conversion",
    "Project scaffolding with templates",
    "RetroVirtualMachine emulator integration",
    "Multi-platform support (macOS, Linux, Windows WSL)",
    "Built-in ABASM assembler and toolchain"
  ],
